# Copy these into Railway → Variables (do NOT commit .env with real values)

# Required — AI services
ANTHROPIC_API_KEY=sk-ant-...
ELEVENLABS_API_KEY=sk_...

# Required — Stock footage
PEXELS_API_KEY=...
PIXABAY_API_KEY=...

# Required — Basic auth (change these before deploying)
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=choose_a_strong_password_here

# Required — Server
NODE_ENV=production
PORT=3001

# Optional — Higgsfield
HIGGSFIELD_AUTH_TOKEN=...

# Optional — Remotion (already set in Dockerfile; override here if needed)
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
