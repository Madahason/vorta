{
  "name": "vorta",
  "version": "0.1.0",
  "description": "AI-powered content production platform",
  "private": true,
  "scripts": {
    "build": "npm run build --prefix client",
    "start": "node server/index.js",
    "client": "cd client && npm run dev",
    "server": "cd server && npm run dev",
    "dev": "concurrently \"npm run client\" \"npm run server\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "deploy": "git checkout production && git merge main && git push origin production && git checkout main && echo 'Deployed to production'"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
