# Dependencies
node_modules/
**/node_modules/

# Environment
.env
.env.local
.env.*.local

# Build output
dist/
build/
out/
.remotion/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Vite
client/dist/

# Projects output (generated at runtime — not source)
projects/

# Clip video files synced at runtime — too large for git; sync logic recreates them
remotion/public/clips/*.mp4
remotion/public/clips/*.webm
remotion/public/clips/*.mov
library/clips/*.mp4
library/clips/*.webm
library/clips/*.mov
library/thumbnails/

# Per-project image/audio files synced at runtime for CLI rendering (resolveRenderAssetPath
# in server/routes/render.js) — regenerated fresh from projects/ on every render
remotion/public/images/
remotion/public/audio/

# Claude Code internal state
.claude/
