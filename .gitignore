# Dependencies
node_modules/
**/node_modules/

# Environment
.env
.env.local
.env.*.local
remotion/.env

# Build output
dist/
build/
out/
.remotion/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Vite
client/dist/

# Projects output (generated at runtime — not source)
projects/

# Clip video files synced at runtime — too large for git; sync logic recreates them
library/clips/*.mp4
library/clips/*.webm
library/clips/*.mov
library/thumbnails/

# Local-only render sync target (per-project images/audio, the shared clip library) —
# regenerated fresh from projects/ and library/clips/ on every render. Deliberately NOT
# under remotion/public/: that's what `remotion lambda sites create` bundles by default,
# and this content must never be part of the Lambda site bundle (Lambda renders fetch it
# from S3 instead — see server/routes/render.js's LOCAL_ASSETS_DIR comment).
remotion/localAssets/

# Claude Code internal state
.claude/
