ANTHROPIC_API_KEY=your-anthropic-api-key
ELEVENLABS_API_KEY=your-elevenlabs-api-key
PORT=3001
NODE_TLS_REJECT_UNAUTHORIZED=0
# Override Higgsfield image model — verify job set type with: higgsfield model list
# HIGGSFIELD_MODEL=nano_banana_2

# Stock footage APIs (free tier available)
# Pexels: https://www.pexels.com/api/
PEXELS_API_KEY=your-pexels-api-key
# Pixabay: https://pixabay.com/api/docs/
PIXABAY_API_KEY=your-pixabay-api-key

# YouTube Data API v3 — required for Video Research "Existing Channel" path
YOUTUBE_API_KEY=your-youtube-api-key

# SerpApi — Google Trends data for VR-6 (free tier: 100 searches/month)
SERPAPI_KEY=your-serpapi-key

# AWS S3 — Remotion Lambda migration, phase 1 (server/services/s3.js, server/services/renderAssets.js)
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# Remotion Lambda migration, phase 4 (server/services/lambdaRender.js) — from
# `npx remotion lambda functions ls` / `npx remotion lambda sites ls` (or getFunctions()/
# getSites() against your deployed account+region) after deploying a function + site
REMOTION_FUNCTION_NAME=your-deployed-function-name
REMOTION_SERVE_URL=your-deployed-site-serve-url
# Optional — leave unset so Remotion picks its own framesPerLambda chunk sizing (the mode
# it's actually tuned for). Only set this to cap simultaneous Lambda instances per render
# if you hit "AWS Concurrency limit reached (Rate Exceeded)" under a low account quota.
# REMOTION_LAMBDA_CONCURRENCY=6
# If you do throttle concurrency low on a large render, deploy your function with a
# generous timeout (e.g. --timeout=900) — low concurrency means fewer, bigger chunks
# (chunk size = totalFrames/concurrency), which need more time per chunk
